MODE=dev
DOMAIN=.qucore.io

SERVICE_PORT=5002

POSTGRES_PORT=5001

DATABASE_URL=postgres://myuser:mypassword@localhost:5001/mydb

REDIS_HOST=127.0.0.1
REDIS_PORT=5000

COOKIES_SECRET=my_cookies_secret
REFRESH_SECRET=my_refresh_secret
ACCESS_SECRET=my_access_secret

REFRESH_AGE=2592000000 # 30 days
ACCESS_AGE=900000      # 15 minutes