# =========================================================================
# APPLICATION CONFIGURATION (TEMPLATE)
# =========================================================================
# INSTRUCTIONS:
# 1. BASE CONFIG (.env): Copy variables from BLOCK #1.
#    Used for local development (npm run dev) and Docker interpolation.
# 2. DOCKER CONFIG (.env.prod): Copy variables from BLOCK #2.
#    These values will override base values INSIDE the containers.
#
# !!! IMPORTANT FOR TESTING (Postman / Thunder Client) !!!
# If you are testing the API locally via Postman on http://localhost:
# In your .env.prod file, you MUST set MODE=dev.
# This disables 'secure' and 'domain' flags on cookies, otherwise
# they will be rejected by Postman/Browsers over non-HTTPS connections.
# =========================================================================


# ---------------------------------------------------------
# BLOCK #1: COMMON & LOCAL BASE (Keep these in your .env)
# ---------------------------------------------------------

MODE=dev
DOMAIN=.qucore.io

# Service Ports (Required here for Docker Compose interpolation)
SERVICE_PORT=5002

# Local Infrastructure (DB and Redis on Host/Localhost)
POSTGRES_PORT=5001
DATABASE_URL=postgres://myuser:mypassword@localhost:5001/mydb

REDIS_HOST=127.0.0.1
REDIS_PORT=5000

# Secrets (Replace with long random strings)
COOKIES_SECRET=my_cookies_secret
REFRESH_SECRET=my_refresh_secret
ACCESS_SECRET=my_access_secret

# Token lifespan in ms
REFRESH_AGE=2592000000 # 30 days
ACCESS_AGE=900000      # 15 minutes


# ---------------------------------------------------------
# BLOCK #2: DOCKER OVERRIDES (Keep these in your .env.prod)
# ---------------------------------------------------------

# Set to 'dev' for Postman/Localhost testing.
# Set to 'prod' for production with HTTPS and real Domain.
MODE=dev

# Database & Redis (Internal Docker Network)
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb
POSTGRES_PORT=5432

# DB Connection string for container-to-container communication
DATABASE_URL=postgres://myuser:mypassword@postgres:5432/mydb

REDIS_HOST=redis
REDIS_PORT=6379