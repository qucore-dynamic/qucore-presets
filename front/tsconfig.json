{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": "src",
    "paths": {
      "@app-components/*": ["app/components/*"],
      "@components-ui/*": ["components/ui/*"],
      "@components-widgets/*": ["components/widgets/*"],
      "@components/*": ["components/*"],
      "@features/*": ["features/*"],
      "@hooks/*": ["hooks/*"],
      "@services/*": ["services/*"],
      "@store/*": ["store/*"],
      "@shared-types/*": ["types/*"],
      "@utils/*": ["utils/*"],
      "@i18n/*": ["i18n/*"],
      "@config/*": ["config/*"],
      "@/*": ["*"]
    }
  },
  "include": ["./next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/app/page.tsx"],
  "exclude": ["node_modules", ".next"]
}
